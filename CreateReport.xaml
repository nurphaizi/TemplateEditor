<PageFunction
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
    xmlns:local="clr-namespace:TemplateEdit"
    x:Class="TemplateEdit.CreateReport"

    x:TypeArguments="sys:String"
    mc:Ignorable="d"
    d:DesignHeight="450" d:DesignWidth="800"
    Title="CreateReport">
    <Grid>
        <Grid.Resources>
            <local:EnumDescriptionConverter x:Key="EnumDescriptionConverter"/>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="{Binding Path=_PageSize.Height,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="{Binding Path=_PageSize.Width,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
            <TextBlock Text="Секции отчета" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
            <Separator/>
            <ComboBox x:Name="reportSectionSelector" ItemsSource="{Binding ReportSections.ReportSections,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" SelectedItem="{Binding ReportSections.SelectedSection}"  Width="112"/>
        </StackPanel>
        <ListBox  x:Name="reportSections"   Grid.Column="0" Grid.Row="1"
                 ItemsSource="{Binding ReportSections.ReportSections,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                 SelectedItem="{Binding ReportSections.SelectedSection}"
                 HorizontalContentAlignment="Stretch"
                 SelectionChanged="reportSections_SelectionChanged">
                <!-- Show enum description -->
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" FontSize="14" Padding="4"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <!-- Dynamic ContextMenu -->
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <!-- Dynamic Add {EnumValue} items -->
                        <MenuItem  Header="Добавить секцию" ItemsSource="{Binding ReportSections.AllSections}">
                            <MenuItem.ItemContainerStyle>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Header" Value="{Binding Converter={StaticResource EnumDescriptionConverter}}"/>
                                    <Setter Property="Command" Value="{Binding DataContext.ReportSections.AddSpecificCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                                    <Setter Property="CommandParameter" Value="{Binding}"/>
                                </Style>
                            </MenuItem.ItemContainerStyle>
                        </MenuItem>
                        <Separator/>
                        <!-- Remove -->
                        <MenuItem Header="Удалить секцию" Command="{Binding ReportSections.RemoveCommand}"/>
                        <Separator/>
                        <!-- Set template section -->
                        <MenuItem Header="Выбрать секцию" Command="{Binding ReportSections.SetReportSectionCommand}"/>
                    </ContextMenu>
                </ListBox.ContextMenu>
            </ListBox>
        <ScrollViewer Visibility="Visible" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      Grid.Column="1" Grid.Row="1">
            <Border  BorderBrush="Gray" BorderThickness="1" Margin="5">
            <Canvas x:Name="templateCanvas" 
            Background="White" AllowDrop="True"/>
            </Border>
        </ScrollViewer>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Height="50" Grid.ColumnSpan="2">
            <Button   Width ="80" Content="Сохранить" Click="Button_Click_Save" />
            <Separator Margin="3" />
            <Button   Width ="80" Content="Отменить" Click="Button_Click_Cancel"/>
        </StackPanel>
    </Grid>
</PageFunction>
