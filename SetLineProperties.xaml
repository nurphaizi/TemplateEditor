<PageFunction
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
    xmlns:media="clr-namespace:System.Windows.Media;assembly=PresentationCore"
    x:Class="TemplateEdit.SetLineProperties"
    x:TypeArguments="sys:String"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TemplateEdit" xmlns:wpfTool="http://schemas.xceed.com/wpf/xaml/toolkit"
    mc:Ignorable="d"
    d:DesignHeight="450" d:DesignWidth="800"
    Title="SetLineProperties">
    <Grid>
        <Grid.Resources>
            <ObjectDataProvider x:Key="PenLineCapValues"
                        MethodName="GetValues"
                        ObjectType="{x:Type sys:Enum}">
                <ObjectDataProvider.MethodParameters>
                    <x:Type TypeName="media:PenLineCap"/>
                </ObjectDataProvider.MethodParameters>
            </ObjectDataProvider>
            <local:ConverterDoubleToString x:Key="converterDoubleToString"/>
            <local:ConverterStringToDouble x:Key="converterStringToDouble"/>
            <local:ColorToBrushConverter x:Key="converterSolidColorBrushToColor"/>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>
        <Label Content="Настройки линии" FontFamily="Arial" FontSize="16" DockPanel.Dock="Top" HorizontalAlignment="Center"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal">
            <Label Content="X1"/>
            <TextBox x:Name="left" Width="200" Margin="3"
                             Text="{Binding Path= LineProperties.X1,Converter={StaticResource converterDoubleToString},Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Label Content="(px)"/>

            <Label Content="Y1"/>
            <TextBox x:Name="top" Width="200" Margin="3" Text="{Binding Path= LineProperties.Y1,Converter={StaticResource converterDoubleToString}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Label Content="(px)"/>
            <Label  Margin ="1" Content="Начало линии"/>
            <ComboBox ItemsSource="{Binding Source={StaticResource PenLineCapValues}}"
                      SelectedItem="{Binding LineProperties.StrokeStartLineCap}" />
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <Label Content="X2"/>
            <TextBox x:Name="right" Width="200" Margin="3"
                             Text="{Binding Path= LineProperties.X2,Converter={StaticResource converterDoubleToString}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Label Content="(px)"/>
            <Label Content="Y2"/>
            <TextBox x:Name="bottom" Width="200" Margin="3"
                             Text="{Binding Path= LineProperties.Y2,Converter={StaticResource converterDoubleToString}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Label Content="(px)"/>
            <Label  Margin ="1" Content="Окончание линии"/>
            <ComboBox ItemsSource="{Binding Source={StaticResource PenLineCapValues}}"
                      SelectedItem="{Binding LineProperties.StrokeEndLineCap}" />
        </StackPanel>
        <StackPanel Grid.Row="3" Orientation="Horizontal">
            <Label Content="Толщина линии"/>
            <TextBox x:Name="thickness" Width="50" Margin="3"
                         Text="{Binding Path= LineProperties.StrokeThickness, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Label Content="(px)"/>
            <Separator Margin="3"/>
            <Slider x:Name="sliderThickness" VerticalAlignment="Center" Maximum="20" Minimum="1" Width="100" Value="{Binding Path= LineProperties.StrokeThickness, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <Separator Margin="3"/>
            <Label Content="Угол"/>
            <TextBox x:Name="angle" Width="50" Margin="3"
                         Text="{Binding Path= LineProperties.Angle, Mode=TwoWay,Converter={StaticResource converterDoubleToString}, UpdateSourceTrigger=PropertyChanged}" />
            <Label Content="гр"/>
            <Slider x:Name="sliderAngle" VerticalAlignment="Center" Maximum="20" Minimum="1" Width="100" Value="{Binding Path= LineProperties.Angle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

        </StackPanel>
        <StackPanel  Grid.Row="4" Orientation="Horizontal">
            <Label Content="Цвет линии"/>
            <wpfTool:ColorPicker x:Name="colorPicker" Width="150" Height="25" Margin="3"
            SelectedColor="{Binding Path= LineProperties.Stroke, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <Separator Margin="3"/>
            <CheckBox x:Name="textToBitmap" Content="Вывод как Bitmap" IsChecked="{Binding Path = LineProperties.ConvertToBitmap,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>
        <Border Grid.Row="6" BorderThickness="2"  BorderBrush="Black" 
                    Width="{Binding Path=_PageSize.Width,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                    Height="{Binding Path=_PageSize.Height,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" 
                >
            <Canvas x:Name="canvas"  Loaded="canvas_Loaded" AllowDrop="True"
                    >
                <Line x:Name="line"  Grid.Row="6"
                  X1="{Binding Path=LineProperties.X1,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" 
                  Y1="{Binding Path=LineProperties.Y1,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                  X2="{Binding Path=LineProperties.X2,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                  Y2="{Binding Path=LineProperties.Y2,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                  StrokeThickness="{Binding Path=LineProperties.StrokeThickness,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                  Stroke="{Binding Path=LineProperties.Stroke,Converter={StaticResource converterSolidColorBrushToColor},Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                  StrokeStartLineCap ="{Binding Path=LineProperties.StrokeStartLineCap,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                  StrokeEndLineCap ="{Binding Path=LineProperties.StrokeEndLineCap,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                   RenderTransformOrigin="0.5,0.5"
                  Opacity="1">
                    <Line.RenderTransform>
                        <RotateTransform Angle="{Binding Path=LineProperties.Angle,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />
                    </Line.RenderTransform>
                </Line>
            </Canvas>
        </Border>
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="100" Margin="5" Click="Button_OK_Click"/>
            <Button Content="Отмена" Width="100" Margin="5" Click="Button_Cancel_Click"/>
        </StackPanel>
    </Grid>
</PageFunction>
