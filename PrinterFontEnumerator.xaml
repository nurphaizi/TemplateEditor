<Page x:Class="TemplateEdit.PrinterFontEnumerator"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TemplateEdit"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PrinterFontEnumerator">
    <Grid>
        <StackPanel Margin="10">
        <ComboBox x:Name="PrinterComboBox" Width="300" Margin="0,0,0,10"/>
        <Button Content="Get Fonts" Width="100" Click="GetFonts_Click"/>
        <ListBox x:Name="FontListBox" Margin="0,10,0,0" Height="200"/>
        </StackPanel>
    </Grid>
</Page>
