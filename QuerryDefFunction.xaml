<PageFunction
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
    x:Class="TemplateEdit.QuerryDefFunction"
    x:TypeArguments="sys:String"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TemplateEdit"
    mc:Ignorable="d"
    d:DesignHeight="450" d:DesignWidth="800"
    Title="QuerryDefFunction"
    Loaded="PageFunction_Loaded">
    <Grid>
        <Grid.Resources>
            <!--<ObjectDataProvider x:Key="EnumValues" MethodName="GetValues"
              ObjectType="{x:Type sys:Enum}">
                <ObjectDataProvider.MethodParameters>
                    <x:Type TypeName="local:DataSourceType"/>
                </ObjectDataProvider.MethodParameters>
            </ObjectDataProvider>-->

            <local:StringToTextConverter x:Key="strTotxt"/>
            <local:KeyValueItemConverter x:Key="KeyValueItemConverter"/>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel>
            <StackPanel  Margin="10" Orientation="Horizontal">
                <ListView x:Name="availableSourcesList"  MaxHeight="200"  MaxWidth ="400 " SelectionMode="Single" AllowDrop="True"  ItemsSource="{Binding AvailableSources}" SelectedValue="{Binding Querry, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"  
                      ScrollViewer.VerticalScrollBarVisibility="Auto"   ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Источник">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Тип" >
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox x:Name="dataSourceType" MinWidth="100" ItemsSource="{Binding Source={x:Static local:EnumHelper.DataSourceTypes}}" 
                                        SelectedValue="{Binding SourceType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Содержание" >
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
                <StackPanel >
                    <Separator Margin="5" />
                    <Button Content="Новый" Width="80" Height="20" Click="NewSource"/>
                    <Separator Margin="5"/>
                    <Button Content="Удалить" Width="80" Height="20" Click="DeleteSource"/>
                    <Button Content="Сохранить" Width="80" Height="20" Click="SaveSourceList"/>
                    <Separator Margin="5"/>
                </StackPanel>
            </StackPanel>
            <TextBlock Text="Выбранный запрос:" FontWeight="Bold" Margin="5"/>
            <TextBlock Text="{Binding Path=Querry, Converter={StaticResource strTotxt}}" TextWrapping="Wrap" Height="60" Background="LightGray" Padding="5"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Margin="10">
            <TextBlock Text="Доступные поля запроса:" FontWeight="Bold" Margin="5"/>
            <ListView x:Name="availableFields" ItemsSource="{Binding Path=AvailableFields,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"
                      MaxHeight="300"
                ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListView.View>
                    <GridView AllowsColumnReorder="true" ColumnHeaderToolTip="Информация о полях запроса">
                        <GridViewColumn DisplayMemberBinding="{Binding Path=Name,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}" Header="Имя" Width="100" />
                        <GridViewColumn DisplayMemberBinding="{Binding Path=type,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}" Header="Тип поля" Width="100"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </StackPanel>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="OK" Width="75" Margin="5" Click="OkButton_Click"/>
            <Button Content="Отмена" Width="75" Margin="5" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</PageFunction>
