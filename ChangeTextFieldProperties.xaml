<PageFunction
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
    x:Class="TemplateEdit.ChangeTextFieldProperties"
    x:TypeArguments="sys:String"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TemplateEdit"
    xmlns:wpfTool="clr-namespace:Xceed.Wpf.Toolkit;assembly=Xceed.Wpf.Toolkit"
    mc:Ignorable="d"
    d:DesignHeight="450" d:DesignWidth="800"
    Title="ChangeTextFieldProperties">
    <Grid>
        <Grid.Resources>
            <local:ConverterDoubleToString x:Key = "doubleToString"/>
            <local:ConverterStringToDouble x:Key="stringToDouble"/>
            <local:ColorToBrushConverter x:Key="colorToBrush"/>
            <local:StringToFontFamilyConverter x:Key="stringToFontFamilyConverter"/>
            <local:AngleToRotationConverter x:Key="angleToRotationConverter"/>
            <local:ConverterFontFamilyToString x:Key="fontFamilyToString"/>
            <local:DictionaryToObservableConverter x:Key="_itemsSource"/>
            <local:DictionaryLookupConverter x:Key="dictionaryLookupConverter"/>
            <local:FieldTypeDescriptionConverter x:Key="fieldTypeDescription"/>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <Label x:Name="functionTitle"     Content="Редактирование текстового поля" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
            <Separator Margin="5"/>
            <StackPanel Orientation="Horizontal" Margin="5" Loaded="StackPanel_Loaded">
                <Label Content="Шрифт" />
                <ComboBox Name="FontSelector"
          ItemsSource="{Binding Path=InstalledFontsList,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}" 
          SelectedItem="{Binding Path=TextFieldValue.FontFamily, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />
                <Label Content="Размер" />
                <TextBox x:Name="fontSize" Text="{Binding Path = TextFieldValue.FontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged,Converter={StaticResource doubleToString }}"
                      FontWeight="{Binding ElementName = Weights, Path=SelectedValue}" Width="50" />
                <Label Content="B" />
                <ComboBox Name="Weights"  SelectedItem="{Binding Path=TextFieldValue.FontWeight,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                    <x:Static Member="FontWeights.Black"/>
                    <x:Static Member="FontWeights.Bold"/>
                    <x:Static Member="FontWeights.DemiBold"/>
                    <x:Static Member="FontWeights.ExtraBlack"/>
                    <x:Static Member="FontWeights.ExtraBold"/>
                    <x:Static Member="FontWeights.ExtraLight"/>
                    <x:Static Member="FontWeights.Heavy"/>
                    <x:Static Member="FontWeights.Light"/>
                    <x:Static Member="FontWeights.Medium"/>
                    <x:Static Member="FontWeights.Normal"/>
                    <x:Static Member="FontWeights.Regular"/>
                    <x:Static Member="FontWeights.SemiBold"/>
                    <x:Static Member="FontWeights.Thin"/>
                    <x:Static Member="FontWeights.UltraBlack"/>
                    <x:Static Member="FontWeights.UltraBold"/>
                    <x:Static Member="FontWeights.UltraLight"/>
                </ComboBox>
                <Label Content="I" />
                <ComboBox Name="Styles" SelectedValue="{Binding Path=TextFieldValue.FontStyle,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                    <x:Static Member="FontStyles.Normal"/>
                    <x:Static Member="FontStyles.Italic"/>
                    <x:Static Member="FontStyles.Oblique"/>
                </ComboBox>
                <Label Content="BG" />
                <wpfTool:ColorPicker x:Name="colorPickerBg" SelectedColor="{Binding Path=TextFieldValue.Background,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />
                <Label Content="FG" />
                <wpfTool:ColorPicker x:Name="colorPickerFg" SelectedColor="{Binding Path=TextFieldValue.Foreground,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />
                <Label Content="Рамка" />
                <TextBox x:Name="borderThickness" Text="{Binding Path=TextFieldValue.BorderThickness,Converter={StaticResource doubleToString},Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="50" />
                <Label Content="Цвет рамки" />
                <wpfTool:ColorPicker x:Name="colorPickerBorder" SelectedColor="{Binding Path=TextFieldValue.BorderColor,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <GroupBox >
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <Label Content="Ширина (px)" />
                        <Separator Margin="3"/>
                        <TextBox x:Name="width" Width="100" Text="{Binding Path=TextFieldValue.Width,Converter={StaticResource doubleToString},Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />
                        <Separator Margin="15"/>
                        <Slider Width="200 " VerticalAlignment="Center" Minimum="10" Maximum="580"    Value ="{Binding TextFieldValue.Width,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <Label Content="Высота (px)" />
                        <Separator Margin="7"/>
                        <TextBox x:Name="height" Width="100" Text="{Binding Path=TextFieldValue.Height,Converter={StaticResource doubleToString},Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                        <Separator Margin="15"/>
                        <Slider Width="200 " VerticalAlignment="Center" Value ="{Binding TextFieldValue.Height,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Minimum="10" Maximum="400"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <Label Content="Положение (px) X" />
                        <Separator Margin="5"/>
                        <TextBox x:Name="left" Width="100" Text="{Binding Path=TextFieldValue.Left,Converter={StaticResource doubleToString},ConverterParameter='px',Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />
                        <Separator Margin="5"/>
                        <Label Content="Y" />
                        <TextBox x:Name="top" Width="100" Text="{Binding Path=TextFieldValue.Top,Converter={StaticResource doubleToString},ConverterParameter='px',Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <Label Content="Угол (гр)" />
                        <Separator Margin="15"/>
                        <TextBox x:Name="angle" Width="100" Text="{Binding Path=TextFieldValue.Angle,Converter={StaticResource doubleToString},Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />
                        <Separator Margin="15"/>
                        <Slider Width="200 " VerticalAlignment="Center" Minimum="0" Maximum="360"    Value ="{Binding TextFieldValue.Angle,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <Label Content="X-множитель: 1~10 " />
                        <Separator Margin="15"/>
                        <TextBox x:Name="x_multiplication" Width="100" Text="{Binding Path=TextFieldValue.XMultiplication,Converter={StaticResource doubleToString},Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />
                        <Separator Margin="15"/>
                        <Slider Width="200 " VerticalAlignment="Center" Minimum="1" Maximum="10"    Value ="{Binding TextFieldValue.XMultiplication,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <Label Content="Y-множитель: 1~10 " />
                        <Separator Margin="15"/>
                        <TextBox x:Name="y_multiplication" Width="100" Text="{Binding Path=TextFieldValue.YMultiplication,Converter={StaticResource doubleToString},Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />
                        <Separator Margin="15"/>
                        <Slider Width="200 " VerticalAlignment="Center" Minimum="1" Maximum="10"    Value ="{Binding TextFieldValue.YMultiplication,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>
            <StackPanel  HorizontalAlignment="Center"  >
                <Label Content="Текст"/>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                    <Separator Margin="3"/>
                    <TextBox x:Name="input_text" Width="{Binding Path=TextFieldValue.Width,Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     MinWidth="100"
                     Height="{Binding Path=TextFieldValue.Height,Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     TextWrapping="{Binding Path=TextFieldValue.TextWrapping,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                     TextAlignment="{Binding Path=TextFieldValue.TextAlignment,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                     HorizontalAlignment="{Binding Path=TextFieldValue.HorizontalAlignment,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                     VerticalAlignment="{Binding Path=TextFieldValue.VerticalAlignment,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="{Binding Path=TextFieldValue.AcceptsReturn,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                     Text="{Binding  Path = TextValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     FontFamily="{Binding Path=TextFieldValue.FontFamily, Converter={StaticResource stringToFontFamilyConverter},Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"
                     FontSize="{Binding Path = TextFieldValue.FontSize, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                     FontWeight="{Binding Path=TextFieldValue.FontWeight, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                     FontStyle="{Binding  Path=TextFieldValue.FontStyle,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                     Background="{Binding Path=TextFieldValue.Background,Converter = {StaticResource colorToBrush },Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                     Foreground="{Binding Path=TextFieldValue.Foreground,Converter={StaticResource colorToBrush},Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                     RenderTransform ="{Binding Path=TextFieldValue.Angle, Converter={StaticResource angleToRotationConverter}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     VerticalScrollBarVisibility = "Auto"/>
                    <Separator Margin="5"/>
                    <ComboBox  SelectedValue="{Binding Path = TextFieldValue.TextAlignment, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                        <x:Static Member="TextAlignment.Left"/>
                        <x:Static Member="TextAlignment.Center"/>
                        <x:Static Member="TextAlignment.Right"/>
                        <x:Static Member="TextAlignment.Justify"/>
                    </ComboBox>
                    <Separator Margin="5"/>
                    <ComboBox  SelectedValue="{Binding Path = TextFieldValue.HorizontalAlignment, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                        <x:Static Member="HorizontalAlignment.Left"/>
                        <x:Static Member="HorizontalAlignment.Center"/>
                        <x:Static Member="HorizontalAlignment.Right"/>
                    </ComboBox>
                    <Separator Margin="5"/>
                    <ComboBox x:Name="vAlignment" SelectedValue="{Binding Path = TextFieldValue.VerticalAlignment, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                        <x:Static Member="VerticalAlignment.Top"/>
                        <x:Static Member="VerticalAlignment.Center"/>
                        <x:Static Member="VerticalAlignment.Bottom"/>
                    </ComboBox>
                </StackPanel>
                <Separator Margin="5"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Label Content="Тип источника" />
                <Separator Margin="3"/>
                <ComboBox x:Name="dataSourceType" ItemsSource="{Binding Source={x:Static local:EnumHelper.DataSourceTypes}}" 
                SelectedValue="{Binding Path = DataSourceType,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  />
                <Label Content="Имя источника" />
                <Separator Margin="3"/>
                <ComboBox x:Name="dataSourceName" MinWidth="150" Margin="3" 
                         ItemsSource="{Binding Path = AvailableSources,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                         DisplayMemberPath="Key"
                         SelectedValue="{Binding Path = DataSourceName,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />
                <Label Content="Имя поля" />
                <Separator Margin="3"/>
                <ComboBox x:Name="dataFieldName" MinWidth="100" Margin="3" ToolTip="{Binding Path=ColumnName.FieldType}"
                          ItemsSource="{Binding Path=ColumnNames,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                          DisplayMemberPath="Key"  SelectedValue = "{Binding  Path=ColumnName,Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBox.ItemContainerStyle>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="IsEnabled" Value="{Binding IsActive}" />
                        <Setter Property="ToolTip">
                            <Setter.Value>
                                    <Binding Path="" Converter="{StaticResource fieldTypeDescription}"/>
                                </Setter.Value>
                        </Setter>
                    </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>
                <ListView x:Name="columnDataList" MaxHeight="80" SelectionChanged="columnDataList_SelectionChanged" Margin="3"/>
                <Separator Margin="3"/>
                <ComboBox x:Name="dataSourceFieldType" ItemsSource="{Binding Source={x:Static local:EnumHelper.DataSourceFieldTypes}}" 
              SelectedValue="{Binding Path=DataSourceFieldType,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="100"/>
            </StackPanel>
            <Separator Margin="3"/>
            <CheckBox x:Name="textToBitmap" Content="Вывод как Bitmap" IsChecked="{Binding Path=TextFieldValue.ConvertToBitmap,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>
        <StackPanel  Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Height="50" >
            <Button x:Name="btSave"  Content="Создать" Click="Button_Click_Save" />
            <Separator Margin="3" />
            <Button   Content="Отменить" Click="Button_Click_Cancel"/>
        </StackPanel>
    </Grid>
</PageFunction>
