<PageFunction
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
    x:Class="TemplateEdit.QRCodePropertiesFunction"
    x:TypeArguments="sys:String"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TemplateEdit"
    mc:Ignorable="d"
    d:DesignHeight="450" d:DesignWidth="800"
    Title="QRCodePropertiesFunction">
    <Grid>
        <Grid.Resources>
            <local:AngleToRotationConverter x:Key="angleToRotationConverter"/>
            <local:SvgStringToBitmapImageConverter x:Key="svgStringToBitmapImageConverter"/>
            <local:ConverterFloatToString x:Key="floatToString"/>
            <local:ConverterDoubleToString x:Key="doubleToString"/>
            <local:FieldTypeDescriptionConverter x:Key="fieldTypeDescription"/>
            <local:SvgBlobToImageConverter x:Key="svgBlobToImageConverter"/>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="37.882"/>
            <RowDefinition Height="42.118"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Row="0"  Grid.ColumnSpan="2"     HorizontalAlignment="Left" Width="196" Margin="302,0,0,0"  >
            <Label x:Name="functionTitle"  Content="Создание поля с QR-кодом" FontSize="120" FontWeight="Bold" HorizontalAlignment="Center"/>
        </StackPanel>
        <StackPanel   Grid.Row="1"  Grid.ColumnSpan="2" Orientation="Horizontal">
            <Separator Margin="3"/>
            <Label Content="Left"/>
            <TextBox   MinWidth="50" Margin="3"
      Text="{Binding Path = QRCodeImageProperties.Left,Converter={StaticResource doubleToString},Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
            <Separator Margin="3"/>
            <Slider  Minimum="0" Maximum="580" Value="{Binding Path=QRCodeImageProperties.Left,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" 
         Width="140" Margin="3" IsSnapToTickEnabled="True" TickFrequency="1" 
         ToolTip="Левая граница"/>
            <Separator Margin="3"/>
            <Label Content="Top"/>
            <TextBox   MinWidth="50" Margin="3"
      Text="{Binding Path=QRCodeImageProperties.Top,Converter={StaticResource doubleToString},Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
            <Separator Margin="3"/>
            <Slider  Minimum="0" Maximum="580" Value="{Binding Path=QRCodeImageProperties.Top,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" 
         Width="119" Margin="3" IsSnapToTickEnabled="True" TickFrequency="1" 
         ToolTip="Левая граница"/>
            <Separator Margin="3"/>
            <Label Content="Угол поворота (гр):" Margin="3"/>
            <TextBox Width="50" Margin="3" Text="{Binding Path=QRCodeImageProperties.Angle,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged, Converter={StaticResource doubleToString}}"/>
            <Separator Margin="3"/>
            <Slider x:Name="angleSlider" Minimum="0" Maximum="360" Value="{Binding Path=QRCodeImageProperties.Angle,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" 
Width="105" Margin="3" IsSnapToTickEnabled="True" TickFrequency="1" 
ToolTip="Угол поворота штрих кода в градусах"/>
        </StackPanel>
        <StackPanel Grid.Row="2"  Grid.ColumnSpan="2" Orientation="Horizontal">
            <Label Content="SVG источник QR-кода"/>
            <TextBox x:Name="svgSource" Margin="3" MinWidth="100" Text="{Binding Path=QRCodeSource,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
            <StackPanel Grid.Row="4"  Orientation="Horizontal">
                <Label Content="Тип источника" />
                <Separator Margin="3"/>
                <ComboBox x:Name="dataSourceType" ItemsSource="{Binding Source={x:Static local:EnumHelper.DataSourceTypes}}" 
                     SelectedValue="{Binding Path=DataSourceType,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                <Separator Margin="3"/>
                <Label Content="Имя" HorizontalAlignment="Center" />
                <Separator Margin="3"/>
                <ComboBox x:Name="dataSourceName" MinWidth="80" Margin="3" 
                    ItemsSource="{Binding Path = AvailableSources,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                    DisplayMemberPath="Key"
                    SelectedValue="{Binding Path = DataSourceName,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" IsEditable="True"/>
                <Label Content="Поле" />
                <Separator Margin="3"/>
                <ComboBox x:Name="dataFieldName" MinWidth="80" Margin="3" ToolTip="{Binding Path=ColumnName.FieldType}"
                     ItemsSource="{Binding Path=ColumnNames,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                     DisplayMemberPath="Key"  SelectedValue = "{Binding  Path=ColumnName,Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEditable="True">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="IsEnabled" Value="{Binding IsActive}" />
                            <Setter Property="ToolTip">
                                <Setter.Value>
                                    <Binding Path="" Converter="{StaticResource fieldTypeDescription}"/>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>
               
                <Separator Margin="3"/>
                <ComboBox x:Name="dataSourceFieldType"  ToolTip ="Тип поля" ItemsSource="{Binding Source={x:Static local:EnumHelper.DataSourceFieldTypes}}" 
              SelectedValue="{Binding Path=DataSourceFieldType,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="100"/>
            </StackPanel>
        </StackPanel>

        <GroupBox Grid.Row="3" Grid.ColumnSpan="2" Header="Размер QR-кода" Margin="3,3,3,3" Grid.RowSpan="2">
            <StackPanel >
                <StackPanel Orientation="Horizontal">
                    <Label Content="Высота (px):" Margin="3"/>
                    <TextBox Width="50" Margin="3" Text="{Binding Path=QRCodeImageProperties.Height,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged, Converter={StaticResource doubleToString}}"/>
                    <Separator Margin="3"/>
                    <Label Content="(mm):"/>
                    <TextBox Width="50" Text="{Binding Path=QRCodeImageProperties.Height,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged, Converter={StaticResource doubleToString},ConverterParameter='mm'}"/>
                    <Separator Margin="3"/>
                    <Slider x:Name="heightSlider" Orientation="Horizontal" Minimum="0" Maximum="400"  MinWidth="80" MinHeight="20" 
                            Height ="{Binding ElementName=qrCodeImage ,Path=ActualHeight,Mode=OneWay}"  
                            Value="{Binding Path= QRCodeImageProperties.Height,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                    <Separator Margin="3"/>
                    <Label Content="Ширина (px):" Margin="3"/>
                    <TextBox Width="50" Margin="3" Text="{Binding Path=QRCodeImageProperties.Width,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged, Converter={StaticResource doubleToString}}"/>
                    <Separator Margin="3"/>
                    <Label Content="Ширина (px):" Margin="3"/>
                    <TextBox Width="50" Margin="3" Text="{Binding Path=QRCodeImageProperties.Width,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged, Converter={StaticResource doubleToString}}"/>
                    <Slider x:Name="widthSlider" Orientation="Horizontal" Minimum="0" Maximum="580" MinWidth="80" MinHeight="20" 
                            Value="{Binding Path= QRCodeImageProperties.Width,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="5" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Top" Height="0" >
            <StackPanel>
                <Canvas x:Name="canvas" >
                    <Image x:Name="qrCodeImage" Margin="5"  Stretch="Fill" Height="{Binding Path= QRCodeImageProperties.Height,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                       Canvas.Left="{Binding Path=QRCodeImageProperties.Left,Converter={StaticResource doubleToString},Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                       Canvas.Top="{Binding Path=QRCodeImageProperties.Top,Converter={StaticResource doubleToString},Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                       Width="{Binding Path= QRCodeImageProperties.Width,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                       Source="{Binding  Path=QRCodeSource, Mode =TwoWay,UpdateSourceTrigger=PropertyChanged,  Converter={StaticResource svgStringToBitmapImageConverter}}"
                       RenderTransformOrigin="0.5,0.5"
                       RenderTransform ="{Binding Path=QRCodeImageProperties.Angle, Converter={StaticResource angleToRotationConverter}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Canvas>
            </StackPanel>
        </StackPanel>
        <StackPanel Grid.Row="5" Grid.Column="1">
                <ListView x:Name="columnDataList" MinHeight="100"  SelectionChanged="columnDataList_SelectionChanged"/>
        </StackPanel>
        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right"  >
            <Button x:Name="btSave" Content="Создать" Click="okButton_Click"/>
            <Separator Margin="3"/>
            <Button Content="Отмена" Click="cancelButton_Click"/>
        </StackPanel>
    </Grid>
</PageFunction>
